  "subRecipes": [
    {
      "id": "sub1",
      "title": "Tahini Sauce Preparation",
      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 220°C (200°C fan/gas mark 7)",
          "time": "10min",
          "tools": [
            "oven"
          ],
          "output": {
            "state": "preheated",
            "description": "Oven preheated to the correct temperature"
          }
        },
        {
          "id": "step2",
          "action": "Place all the ingredients for the tahini sauce in a medium bowl with a pinch of salt. Whisk together and set aside",
          "time": "5min",
          "tools": [
            "bowl",
            "whisk"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing10"
            },
            {
              "type": "ingredient",
              "ref": "ing11"
            },
            {
              "type": "ingredient",
              "ref": "ing12"
            },
            {
              "type": "ingredient",
              "ref": "ing13"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            }
          ],
          "output": {
            "state": "tahini sauce prepared",
            "description": "Tahini sauce well combined and set aside"
          }
        }
      ]
    },
    {
      "id": "sub2",
      "title": "Carrots Preparation",
      "steps": [
        {
          "id": "step3",
          "action": "Place the honey, oil, coriander and cumin seeds, and thyme in a large mixing bowl with 1 teaspoon of salt and a good grind of black pepper. Add the carrots and mix well until coated",
          "time": "5min",
          "tools": [
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            },
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing3"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            },
            {
              "type": "ingredient",
              "ref": "ing5"
            },
            {
              "type": "ingredient",
              "ref": "ing6"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            },
            {
              "type": "ingredient",
              "ref": "ing9"
            }
          ],
          "output": {
            "state": "carrots coated",
            "description": "Carrots well mixed with seasoning and ready for roasting"
          }
        },
        {
          "id": "step4",
          "action": "Spread the coated carrots out on a large baking tray and roast in the oven for 40 minutes, stirring gently once or twice, until cooked through and glazed",
          "time": "40min",
          "tools": [
            "baking tray"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step3"
            }
          ],
          "output": {
            "state": "carrots roasted",
            "description": "Carrots are roasted to a golden colour and glazed"
          }
        },
        {
          "id": "step5",
          "action": "Transfer the roasted carrots to a large serving platter or individual plates. Serve warm or at room temperature, with a spoonful of tahini sauce on top, scattered with the coriander leaves",
          "time": "5min",
          "tools": [
            "serving platter",
            "spoon"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step4"
            },
            {
              "type": "state",
              "ref": "step2"
            },
            {
              "type": "ingredient",
              "ref": "ing7"
            }
          ],
          "output": {
            "state": "served",
            "description": "Honey-roasted carrots served with tahini sauce and garnished with coriander leaves"
          }
        }
      ]
