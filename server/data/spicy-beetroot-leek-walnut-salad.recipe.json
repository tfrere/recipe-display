  "subRecipes": [
    {
      "id": "sub1",
      "title": "Roasting Beetroot",
      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 220ºC/200ºC fan/gas mark 7.",
          "time": "10min",
          "tools": [
            "oven"
          ],
          "output": {
            "state": "preheated",
            "description": "Oven preheated to correct temperature"
          }
        },
        {
          "id": "step2",
          "action": "Wrap the beetroots individually in tin foil and roast them in the oven for 60–90 minutes, depending on their size. Once cooked, you should be able to stick a small knife through to the center easily. Remove from the oven and set aside to cool.",
          "time": "1h30min",
          "tools": [
            "oven",
            "tin foil",
            "knife"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            }
          ],
          "output": {
            "state": "roasted",
            "description": "Beetroots roasted and set aside to cool"
          }
        },
        {
          "id": "step3",
          "action": "Once cool enough to handle, peel the beets, halve them and cut each half into wedges, 1cm thick at the base. Put in a medium bowl and set aside.",
          "time": "10min",
          "tools": [
            "knife",
            "bowl"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step2"
            }
          ],
          "output": {
            "state": "prepared",
            "description": "Beetroots peeled, halved, and cut into wedges"
          }
        }
      ]
    },
    {
      "id": "sub2",
      "title": "Preparing Leeks",
      "steps": [
        {
          "id": "step4",
          "action": "Place the leeks in a medium pan with salted water, bring to the boil and simmer for 10 minutes, until just cooked; it’s important to simmer them gently and not to overcook them so they don’t fall apart. Drain and refresh under cold water, then use a very sharp serrated knife to cut each segment into 3 smaller pieces and pat dry. Transfer to a bowl, separate from the beets, and set aside.",
          "time": "20min",
          "tools": [
            "pan",
            "knife",
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing13"
            }
          ],
          "output": {
            "state": "cooked",
            "description": "Leeks boiled, refreshed, and cut into smaller pieces"
          }
        }
      ]
    },
    {
      "id": "sub3",
      "title": "Preparing Dressing",
      "steps": [
        {
          "id": "step5",
          "action": "While the vegetables are cooking, mix all the dressing ingredients and leave to one side for at least 10 minutes for all the flavours to come together.",
          "time": "10min",
          "tools": [
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing7"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            },
            {
              "type": "ingredient",
              "ref": "ing9"
            },
            {
              "type": "ingredient",
              "ref": "ing10"
            },
            {
              "type": "ingredient",
              "ref": "ing11"
            },
            {
              "type": "ingredient",
              "ref": "ing12"
            }
          ],
          "output": {
            "state": "mixed",
            "description": "Dressing ingredients mixed and set aside to infuse"
          }
        }
      ]
    },
    {
      "id": "sub4",
      "title": "Assembling the Salad",
      "steps": [
        {
          "id": "step6",
          "action": "Divide the walnut dressing and the fresh coriander equally between the beets and the leeks and toss gently. Taste both and add more salt if needed.",
          "time": "5min",
          "inputs": [
            {
              "type": "state",
              "ref": "step3"
            },
            {
              "type": "state",
              "ref": "step4"
            },
            {
              "type": "state",
              "ref": "step5"
            },
            {
              "type": "ingredient",
              "ref": "ing3"
            }
          ],
          "output": {
            "state": "combined",
            "description": "Beetroots and leeks tossed with dressing and coriander"
          }
        },
        {
          "id": "step7",
          "action": "To put the salad together, spread most of the beetroot on a serving platter, top with some rocket, then most of the leeks, then the remaining beetroot and finish with more leek and rocket. Sprinkle over the pomegranate seeds, if using, and serve.",
          "time": "5min",
          "tools": [
            "serving platter"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step6"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            },
            {
              "type": "ingredient",
              "ref": "ing5"
            }
          ],
          "output": {
            "state": "assembled",
            "description": "Salad assembled on a platter with layers of beetroot, rocket, and leeks, topped with pomegranate seeds"
          }
        }
      ]
    }
  ]
