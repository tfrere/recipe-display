          "tools": [
            "torchon"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "cuisson-genoise"
            }
          ],
          "output": {
            "state": "déroulé",
            "description": "Génoise déroulée et prête"
          }
        },
        {
          "id": "etaler-creme",
          "action": "Étaler la crème pâtissière",
          "time": "5min",
          "tools": [
            "spatule"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "deroulage"
            },
            {
              "type": "step",
              "ref": "creme-noisette"
            }
          ],
          "output": {
            "state": "étalé",
            "description": "Crème étalée uniformément"
          }
        },
        {
          "id": "roulage",
          "action": "Rouler la bûche",
          "time": "5min",
          "tools": [
            "torchon"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "etaler-creme"
            }
          ],
          "output": {
            "state": "roulé",
            "description": "Bûche roulée"
          }
        },
        {
          "id": "nappage",
          "action": "Napper avec la crème au chocolat et décorer",
          "time": "10min",
          "tools": [
            "spatule"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "roulage"
            },
            {
              "type": "step",
              "ref": "creme-chocolat"
            }
          ],
          "output": {
            "state": "nappé",
            "description": "Bûche nappée et décorée"
          }
        }
      ]
    }
