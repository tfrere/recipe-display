          "time": "15min",
          "tools": [
            "casserole"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "lait"
            },
            {
              "type": "ingredient",
              "ref": "vanille"
            }
          ],
          "output": {
            "state": "infusé",
            "description": "Lait vanillé chaud"
          }
        },
        {
          "id": "jaunes-sucre",
          "action": "Blanchir les jaunes avec le sucre",
          "time": "5min",
          "tools": [
            "fouet"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "jaunes"
            },
            {
              "type": "ingredient",
              "ref": "sucre"
            }
          ],
          "output": {
            "state": "blanchi",
            "description": "Mélange jaunes-sucre blanchi"
          }
        },
        {
          "id": "creme-base",
          "action": "Cuire la crème pâtissière",
          "time": "10min",
          "tools": [
            "casserole",
            "fouet"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "vanille-lait"
            },
            {
              "type": "step",
              "ref": "jaunes-sucre"
            },
            {
              "type": "ingredient",
              "ref": "farine"
            }
          ],
          "output": {
            "state": "cuit",
            "description": "Crème pâtissière de base"
          }
        },
        {
          "id": "creme-noisette",
          "action": "Incorporer la poudre de noisette",
          "time": "5min",
          "tools": [
            "spatule"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "creme-base"
            },
            {
              "type": "ingredient",
              "ref": "poudre-noisette"
            }
          ],
          "output": {
            "state": "mélangé",
            "description": "Crème pâtissière aux noisettes"
          }
        }
      ]
    },
    {
      "id": "dressage",
      "title": "Dressage",
      "steps": [
        {
          "id": "deroulage",
          "action": "Dérouler délicatement la génoise",
