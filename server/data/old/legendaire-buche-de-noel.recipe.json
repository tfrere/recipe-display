  "subRecipes": [
    {
      "id": "creme-italienne",
      "title": "Crème italienne au chocolat",
      "steps": [
        {
          "id": "chocolat",
          "action": "Faire fondre le chocolat au bain-marie",
          "time": "10min",
          "tools": [
            "casserole",
            "bol"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "chocolat-noir"
            }
          ],
          "output": {
            "state": "fondu",
            "description": "Chocolat fondu en crème épaisse"
          }
        },
        {
          "id": "sirop",
          "action": "Cuire le sirop de sucre",
          "time": "10min",
          "tools": [
            "casserole",
            "thermomètre"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "sucre"
            }
          ],
          "output": {
            "state": "sirop",
            "description": "Sirop de sucre à 121°C"
          }
        },
        {
          "id": "jaunes-montes",
          "action": "Monter les jaunes d'œufs",
          "time": "5min",
          "tools": [
            "batteur"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "jaunes"
            }
          ],
          "output": {
            "state": "monté",
            "description": "Jaunes montés mousseux"
          }
        },
        {
          "id": "creme-italienne",
          "action": "Verser le sirop sur les jaunes et monter au batteur",
          "time": "10min",
          "tools": [
            "batteur"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "jaunes-montes"
            },
            {
              "type": "step",
              "ref": "sirop"
            }
          ],
          "output": {
            "state": "monté",
            "description": "Crème italienne montée et refroidie"
          }
        },
        {
          "id": "creme-chocolat",
          "action": "Incorporer le chocolat fondu à la crème italienne",
          "time": "5min",
          "tools": [
            "spatule"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "creme-italienne"
            },
            {
              "type": "step",
              "ref": "chocolat"
            }
          ],
          "output": {
            "state": "mélangé",
            "description": "Crème italienne au chocolat"
          }
        }
      ]
    },
    {
      "id": "genoise",
      "title": "Génoise",
      "steps": [
        {
          "id": "oeufs-sucre",
          "action": "Monter les œufs avec le sucre",
