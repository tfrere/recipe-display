          "tools": [
            "batteur"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "oeufs"
            },
            {
              "type": "ingredient",
              "ref": "sucre-poudre"
            }
          ],
          "output": {
            "state": "monté",
            "description": "Œufs montés mousseux"
          }
        },
        {
          "id": "farine-tamis",
          "action": "Tamiser la farine avec la maïzena",
          "time": "5min",
          "tools": [
            "tamis"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "farine"
            },
            {
              "type": "ingredient",
              "ref": "maizena"
            }
          ],
          "output": {
            "state": "tamisé",
            "description": "Mélange de farines tamisé"
          }
        },
        {
          "id": "genoise",
          "action": "Incorporer délicatement les farines aux œufs montés",
          "time": "5min",
          "tools": [
            "spatule"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "oeufs-sucre"
            },
            {
              "type": "step",
              "ref": "farine-tamis"
            }
          ],
          "output": {
            "state": "mélangé",
            "description": "Pâte à génoise prête"
          }
        },
        {
          "id": "cuisson-genoise",
          "action": "Cuire la génoise",
          "time": "12min",
          "tools": [
            "four",
            "plaque"
          ],
          "inputs": [
            {
              "type": "step",
              "ref": "genoise"
            }
          ],
          "output": {
            "state": "cuit",
            "description": "Génoise cuite et dorée"
          }
        }
      ]
    },
    {
      "id": "creme-patissiere",
      "title": "Crème pâtissière aux noisettes",
      "steps": [
        {
          "id": "vanille-lait",
