      "title": "Roasting the Lemons",
      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 170°C/150°C fan/gas mark 3½.",
          "time": "10min",
          "tools": [
            "oven"
          ],
          "output": {
            "state": "preheated",
            "description": "Oven preheated to correct temperature"
          }
        },
        {
          "id": "step2",
          "action": "Blanch the lemon slices in boiling water for 2 minutes, then drain.",
          "time": "5min",
          "tools": [
            "saucepan",
            "stove"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            }
          ],
          "output": {
            "state": "blanched",
            "description": "Lemon slices blanched and drained"
          }
        },
        {
          "id": "step3",
          "action": "Mix the blanched lemon slices with 1 tablespoon of oil, salt, sugar, and sage, then spread on a baking tray and roast for 20 minutes.",
          "time": "20min",
          "tools": [
            "bowl",
            "baking tray"
          ],
