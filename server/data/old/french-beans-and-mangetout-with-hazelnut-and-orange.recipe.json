{
  "metadata": {
    "title": "French Beans and Mangetout with Hazelnut and Orange",
    "description": "A vibrant and refreshing salad combining french beans and mangetout with the crunch of hazelnuts and the zest of orange, perfect for festive gatherings.",
    "servings": 6,
    "difficulty": "easy",
    "totalTime": "35min",
    "image": "french-beans-and-mangetout-with-hazelnut-and-orange.jpg",
    "imageUrl": "http://recipes.tfrere.com/recipes/french-beans-and-mangetout-with-hazelnut-and-orange/images/french-beans-and-mangetout-with-hazelnut-and-orange.jpg",
    "sourceUrl": "http://recipes.tfrere.com/recipes/french-beans-and-mangetout-with-hazelnut-and-orange/index.html"
  },
  "ingredientsList": [
    {
      "id": "ing1",
      "name": "french beans",
      "unit": "g",
      "amount": 400,
      "category": "fruits-legumes"
    },
    {
      "id": "ing2",
      "name": "mangetout",
      "unit": "g",
      "amount": 400,
      "category": "fruits-legumes"
    },
    {
      "id": "ing3",
      "name": "unskinned hazelnuts",
      "unit": "g",
      "amount": 70,
      "category": "epicerie-sucree"
    },
    {
      "id": "ing4",
      "name": "orange",
      "unit": "unit",
      "amount": 1,
      "category": "fruits-legumes"
    },
    {
      "id": "ing5",
      "name": "chives",
      "unit": "g",
      "amount": 20,
      "category": "fruits-legumes"
    },
    {
      "id": "ing6",
      "name": "garlic clove",
      "unit": "unit",
      "amount": 1,
      "category": "fruits-legumes"
    },
    {
      "id": "ing7",
      "name": "olive oil",
      "unit": "tbsp",
      "amount": 3,
      "category": "condiments"
    },
    {
      "id": "ing8",
      "name": "hazelnut oil",
      "unit": "tbsp",
      "amount": 2,
      "category": "condiments"
    },
    {
      "id": "ing9",
      "name": "flaky sea salt",
      "unit": "tsp",
      "amount": 0.5,
      "category": "condiments"
    },
    {
