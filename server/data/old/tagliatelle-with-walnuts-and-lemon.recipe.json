              "ref": "ing8"
            },
            {
              "type": "ingredient",
              "ref": "ing9"
            }
          ],
          "output": {
            "state": "dish_assembled",
            "description": "Pasta mixed with sauce, walnuts, parmesan, parsley, and lemon juice, ready to serve"
          }
        }
      ]
    }
  ]
