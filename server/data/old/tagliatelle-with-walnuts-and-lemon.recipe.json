  "metadata": {
    "title": "Tagliatelle with Walnuts and Lemon",
    "description": "A rich and flavorful pasta dish with walnuts, lemon, and parmesan cheese.",
    "servings": 2,
    "difficulty": "easy",
    "totalTime": "25min",
    "image": "tagliatelle-with-walnuts-and-lemon.jpg",
