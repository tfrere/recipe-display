  "subRecipes": [
    {
      "id": "laap",
      "title": "Laap Thailandais",
      "steps": [
        {
          "id": "aromates",
          "action": "Préparer les aromates",
          "time": "10min",
          "tools": ["couteau", "planche à découper"],
          "inputs": [
            {"type": "ingredient", "ref": "combawa"},
            {"type": "ingredient", "ref": "citronnelle"},
            {"type": "ingredient", "ref": "menthe"},
            {"type": "ingredient", "ref": "coriandre"},
            {"type": "ingredient", "ref": "galanga"},
            {"type": "ingredient", "ref": "ail"},
            {"type": "ingredient", "ref": "piment"},
            {"type": "ingredient", "ref": "gingembre"}
          ],
          "output": {
            "state": "haché",
            "description": "Tous les aromates sont finement hachés"
          }
        },
        {
          "id": "seitan",
          "action": "Préparer le seitan",
          "time": "10min",
          "tools": ["couteau", "planche à découper", "poêle"],
          "inputs": [
            {"type": "ingredient", "ref": "seitan"},
            {"type": "ingredient", "ref": "huile-vegetale"}
          ],
          "output": {
            "state": "haché et cuit",
            "description": "Le seitan est haché finement et cuit"
          }
        },
        {
          "id": "riz",
          "action": "Griller le riz",
          "time": "5min",
          "tools": ["poêle"],
          "inputs": [
            {"type": "ingredient", "ref": "riz"}
          ],
          "output": {
            "state": "grillé",
            "description": "Le riz est grillé et concassé"
          }
        },
        {
          "id": "choux",
          "action": "Préparer les choux",
          "time": "15min",
          "tools": ["casserole"],
          "inputs": [
            {"type": "ingredient", "ref": "choux"}
          ],
          "output": {
            "state": "blanchi",
            "description": "Les choux sont blanchis et coupés"
          }
        },
        {
          "id": "epinards",
          "action": "Cuire les épinards et la livèche",
          "time": "5min",
          "tools": ["casserole"],
          "inputs": [
            {"type": "ingredient", "ref": "epinard"},
            {"type": "ingredient", "ref": "liveche"}
          ],
          "output": {
            "state": "blanchi",
            "description": "Les épinards et la livèche sont blanchis"
          }
        },
        {
          "id": "creme-epinard",
          "action": "Réaliser la crème d'épinards",
          "time": "10min",
          "tools": ["blender"],
          "inputs": [
            {"type": "step", "ref": "epinards"},
            {"type": "ingredient", "ref": "creme"}
          ],
          "output": {
            "state": "mixé",
            "description": "La crème d'épinards est lisse"
          }
        },
        {
          "id": "assemblage-laap",
          "action": "Assembler le laap",
          "time": "5min",
          "tools": ["saladier"],
          "inputs": [
            {"type": "step", "ref": "aromates"},
            {"type": "step", "ref": "seitan"},
            {"type": "step", "ref": "riz"},
            {"type": "ingredient", "ref": "sauce-soja"},
            {"type": "ingredient", "ref": "miso-lentille"}
          ],
          "output": {
            "state": "mélangé",
            "description": "Le laap est assemblé et assaisonné"
          }
        }
      ]
    },
    {
      "id": "caramel",
      "title": "Caramel de vin rouge",
      "steps": [
        {
          "id": "caramel-base",
          "action": "Réaliser le caramel",
          "time": "10min",
          "tools": ["casserole"],
          "inputs": [
            {"type": "ingredient", "ref": "sucre"}
          ],
          "output": {
            "state": "caramélisé",
            "description": "Le sucre est transformé en caramel ambré"
          }
        },
        {
          "id": "deglacage",
          "action": "Déglacer au vin rouge",
          "time": "5min",
          "tools": ["casserole"],
          "inputs": [
            {"type": "step", "ref": "caramel-base"},
            {"type": "ingredient", "ref": "vin-rouge"}
          ],
          "output": {
            "state": "réduit",
            "description": "Le caramel est déglacé et réduit"
          }
        },
        {
          "id": "echalotes",
          "action": "Sauter les échalotes",
          "time": "10min",
          "tools": ["poêle"],
          "inputs": [
            {"type": "ingredient", "ref": "echalote"}
          ],
          "output": {
            "state": "caramélisé",
            "description": "Les échalotes sont caramélisées"
          }
        },
        {
          "id": "crosnes",
          "action": "Préparer les crosnes",
          "time": "15min",
          "tools": ["poêle"],
          "inputs": [
            {"type": "ingredient", "ref": "crosne"}
          ],
          "output": {
            "state": "caramélisé",
            "description": "Les crosnes sont caramélisés"
          }
        }
      ]
    },
    {
      "id": "tuile",
      "title": "Tuile de manioc",
      "steps": [
        {
          "id": "pate-tuile",
          "action": "Préparer la pâte",
          "time": "10min",
          "tools": ["bol", "fouet"],
          "inputs": [
            {"type": "ingredient", "ref": "farine-manioc"},
            {"type": "ingredient", "ref": "citron-bouddha"}
          ],
          "output": {
            "state": "mélangé",
            "description": "La pâte est homogène"
          }
        },
        {
          "id": "cuisson-tuile",
          "action": "Cuire les tuiles",
          "time": "15min",
          "tools": ["plaque de cuisson", "papier sulfurisé"],
          "inputs": [
            {"type": "step", "ref": "pate-tuile"}
          ],
          "output": {
            "state": "cuit",
            "description": "Les tuiles sont dorées et croustillantes"
          }
        }
      ]
    },
    {
      "id": "dressage",
      "title": "Dressage",
      "steps": [
        {
          "id": "dressage-final",
          "action": "Dresser l'assiette",
          "time": "5min",
          "tools": ["assiette"],
          "inputs": [
            {"type": "step", "ref": "assemblage-laap"},
            {"type": "step", "ref": "deglacage"},
            {"type": "step", "ref": "cuisson-tuile"},
            {"type": "step", "ref": "creme-epinard"},
            {"type": "step", "ref": "echalotes"},
            {"type": "step", "ref": "crosnes"}
          ],
          "output": {
            "state": "dressé",
            "description": "L'assiette est dressée harmonieusement avec tous les éléments"
          }
        }
      ]
    }
  ]
}
