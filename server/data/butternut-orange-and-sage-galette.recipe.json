{
  "metadata": {
    "title": "Butternut, Orange and Sage Galette",
    "description": "A savory galette featuring butternut squash and carrots with an orange and sage-infused mascarpone filling, all encased in a hyper-flaky polenta pastry.",
    "servings": 4,
    "difficulty": "medium",
    "totalTime": "2h45min",
    "image": "butternut-orange-and-sage-galette.jpg",
    "imageUrl": "http://recipes.tfrere.com/recipes/butternut-orange-and-sage-galette/images/butternut-orange-and-sage-galette.jpg",
