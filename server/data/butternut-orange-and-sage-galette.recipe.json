  "subRecipes": [
    {
      "id": "sub1",
      "title": "Pastry Preparation",
      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 220°C fan.",
          "time": "10min",
          "tools": [
            "oven"
          ],
          "output": {
            "state": "preheated",
            "description": "Oven preheated to the correct temperature."
          }
        },
        {
          "id": "step2",
          "action": "Mix the plain flour, wholemeal flour, polenta, caster sugar, flaked sea salt, black pepper, and 1 tbsp of chopped sage leaves in a large bowl.",
          "time": "5min",
          "tools": [
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing12"
            },
            {
              "type": "ingredient",
              "ref": "ing13"
            },
            {
              "type": "ingredient",
              "ref": "ing14"
            },
            {
              "type": "ingredient",
              "ref": "ing15"
            },
            {
              "type": "ingredient",
              "ref": "ing16"
            },
            {
              "type": "ingredient",
              "ref": "ing17"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            }
          ],
          "output": {
            "state": "mixed",
            "description": "Dry ingredients for pastry well combined."
          }
        },
        {
          "id": "step3",
          "action": "Incorporate the cold butter into the flour mixture, then add ice-cold water to form the dough.",
          "time": "10min",
          "tools": [
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing18"
            },
            {
              "type": "ingredient",
              "ref": "ing19"
            },
            {
              "type": "state",
              "ref": "step2"
            }
          ],
          "output": {
            "state": "dough formed",
            "description": "Pastry dough formed with chunks of butter throughout."
          }
        },
        {
          "id": "step4",
          "action": "Roll, fold, and shape the dough, then refrigerate for 30 minutes.",
          "time": "40min",
          "tools": [
            "work surface",
            "rolling pin",
            "cling film"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step3"
            }
          ],
          "output": {
            "state": "chilled",
            "description": "Pastry dough rolled, folded, and chilled."
          }
        }
      ]
    },
    {
      "id": "sub2",
      "title": "Vegetable Preparation",
      "steps": [
        {
          "id": "step5",
          "action": "Toss the butternut squash and carrots with olive oil, chopped sage, caraway seeds, salt, and pepper, and spread on parchment-lined trays. Prepare garlic and shallot for roasting.",
          "time": "15min",
          "tools": [
            "tray",
            "parchment paper"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            },
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing3"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            },
            {
              "type": "ingredient",
              "ref": "ing5"
            },
            {
              "type": "ingredient",
              "ref": "ing6"
            },
            {
              "type": "ingredient",
              "ref": "ing7"
            }
          ],
          "output": {
            "state": "prepared for roasting",
            "description": "Vegetables mixed with seasonings and ready for roasting."
          }
        },
        {
          "id": "step6",
          "action": "Roast the butternut squash and carrots for 25 minutes, then continue roasting the garlic and shallot for an additional 15 minutes.",
          "time": "40min",
          "tools": [
            "oven",
            "tray"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step5"
            }
          ],
          "output": {
            "state": "roasted",
            "description": "Butternut squash and carrots roasted until golden-brown, and garlic and shallot softened."
          }
        },
        {
          "id": "step7",
          "action": "Chop the roasted garlic and shallot, and reduce the oven temperature to 200°C fan.",
          "time": "10min",
          "inputs": [
            {
              "type": "state",
              "ref": "step6"
            }
          ],
          "output": {
            "state": "chopped",
            "description": "Roasted garlic and shallot finely chopped."
          }
        }
      ]
    },
    {
      "id": "sub3",
      "title": "Galette Assembly",
      "steps": [
        {
          "id": "step8",
          "action": "Roll out the chilled dough into a 30cm-wide circle and refrigerate for another 30 minutes.",
          "time": "35min",
          "tools": [
            "work surface",
            "rolling pin"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step4"
            }
          ],
          "output": {
            "state": "chilled",
            "description": "Pastry dough rolled out and chilled for assembly."
          }
        },
        {
          "id": "step9",
          "action": "Cook the orange juice and maple syrup to reduce into a thickened, sticky syrup.",
          "time": "10min",
          "tools": [
            "saucepan"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing8"
            },
            {
              "type": "ingredient",
              "ref": "ing9"
            }
          ],
          "output": {
            "state": "reduced",
            "description": "Orange juice and maple syrup reduced to a thick caramel."
          }
        },
        {
          "id": "step10",
          "action": "Combine mascarpone, chopped garlic and shallot, orange zest, remaining chopped sage, salt, and pepper in a bowl.",
          "time": "5min",
          "tools": [
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing10"
            },
            {
              "type": "state",
              "ref": "step7"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            }
          ],
          "output": {
            "state": "mixture prepared",
            "description": "Mascarpone mixture prepared with garlic, shallot, orange zest, and sage."
          }
        },
        {
          "id": "step11",
          "action": "Spread the mascarpone mixture on the dough, arrange the roasted vegetables, drizzle the orange caramel, and fold the pastry edges. Brush with beaten egg.",
          "time": "15min",
          "tools": [
            "brush"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step8"
            },
            {
              "type": "state",
              "ref": "step9"
            },
            {
              "type": "state",
              "ref": "step10"
            },
            {
              "type": "state",
              "ref": "step6"
            },
            {
              "type": "ingredient",
              "ref": "ing11"
            }
          ],
          "output": {
            "state": "assembled",
            "description": "Galette assembled with mascarpone mixture, roasted vegetables, and orange caramel with folded edges."
          }
        },
        {
          "id": "step12",
          "action": "Bake the galette for 30 minutes until golden-brown, then cool for 20 minutes.",
          "time": "50min",
          "tools": [
            "oven"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step11"
            }
          ],
          "output": {
            "state": "baked",
            "description": "Galette baked and cooled, ready to be served."
          }
        }
      ]
    }
  ]
}