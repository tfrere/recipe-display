  "subRecipes": [
    {
      "id": "base-aromatique",
      "title": "Base aromatique",
      "steps": [
        {
          "id": "chauffer",
          "action": "Faire chauffer une grande marmite à feu moyen",
          "time": "2min",
          "tools": ["large-pot"],
          "inputs": [],
          "output": {
            "state": "chaud",
            "description": "La marmite est chaude et prête à l'emploi"
          }
        },
        {
          "id": "oignons",
          "action": "Faire revenir les oignons à feu moyen-doux jusqu'à ce qu'ils soient translucides",
          "time": "5min",
          "tools": ["large-pot", "wooden-spoon"],
          "inputs": [
            {"type": "ingredient", "ref": "onions"}
          ],
          "output": {
            "state": "translucide",
            "description": "Les oignons sont translucides"
          }
        },
        {
          "id": "ail",
          "action": "Ajouter l'ail et faire revenir jusqu'à ce que les oignons soient dorés",
          "time": "2min",
          "tools": ["large-pot", "wooden-spoon"],
          "inputs": [
            {"type": "ingredient", "ref": "garlic"},
            {"type": "step", "ref": "oignons"}
          ],
          "output": {
            "state": "doré",
            "description": "Les oignons sont dorés et l'ail est revenu"
          }
        }
      ]
    },
    {
      "id": "chili",
      "title": "Chili",
      "steps": [
        {
          "id": "melange",
          "action": "Ajouter tous les ingrédients : les poivrons, les haricots, les tomates concassées, la sauce tomate, le jalapeño et toutes les épices",
          "time": "5min",
          "tools": ["large-pot", "wooden-spoon"],
          "inputs": [
            {"type": "step", "ref": "ail"},
            {"type": "ingredient", "ref": "green-bell-pepper"},
            {"type": "ingredient", "ref": "red-bell-pepper"},
            {"type": "ingredient", "ref": "beans"},
            {"type": "ingredient", "ref": "diced-tomatoes"},
            {"type": "ingredient", "ref": "jalapeno"},
            {"type": "ingredient", "ref": "chili-powder"},
            {"type": "ingredient", "ref": "cocoa-powder"},
            {"type": "ingredient", "ref": "oregano"},
            {"type": "ingredient", "ref": "tomato-sauce"},
            {"type": "ingredient", "ref": "cumin"}
          ],
          "output": {
            "state": "mélangé",
            "description": "Tous les ingrédients sont mélangés dans la marmite"
          }
        },
        {
          "id": "ebullition",
          "action": "Couvrir et porter à ébullition",
          "time": "10min",
          "tools": ["large-pot"],
          "inputs": [
            {"type": "step", "ref": "melange"}
          ],
          "output": {
            "state": "bouillant",
            "description": "Le chili est à ébullition"
          }
        },
        {
          "id": "mijoter",
          "action": "Réduire le feu et laisser mijoter doucement, en remuant de temps en temps, jusqu'à ce que les poivrons soient tendres et que les saveurs se soient mélangées",
          "time": "30min",
          "tools": ["large-pot", "wooden-spoon"],
          "inputs": [
            {"type": "step", "ref": "ebullition"}
          ],
          "output": {
            "state": "cuit",
            "description": "Le chili a mijoté et les poivrons sont tendres"
          }
        }
      ]
    },
    {
      "id": "dressage",
      "title": "Dressage",
      "steps": [
        {
          "id": "servir",
          "action": "Assaisonner avec du sel et du poivre, puis servir",
          "time": "2min",
          "tools": [],
          "inputs": [
            {"type": "step", "ref": "mijoter"}
          ],
          "output": {
            "state": "servi",
            "description": "Le chili est assaisonné et servi"
          }
        }
      ]
    }
  ]
}
