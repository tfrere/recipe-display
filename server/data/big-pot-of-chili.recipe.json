  "subRecipes": {
    "chili": {
      "title": "Chili végétarien",
      "ingredients": {
        "onions": { "amount": 2 },
        "garlic": { "amount": 5 },
        "green-bell-pepper": { "amount": 1 },
        "red-bell-pepper": { "amount": 1 },
        "beans": { "amount": 2380 },
        "diced-tomatoes": { "amount": 800 },
        "jalapeno": { "amount": 1 },
        "chili-powder": { "amount": 1 },
        "cocoa-powder": { "amount": 1 },
        "oregano": { "amount": 2 },
        "tomato-sauce": { "amount": 450 },
        "cumin": { "amount": 2 }
      },
      "steps": [
        {
          "id": "step-1",
          "action": "Faire chauffer une grande marmite à feu moyen.",
          "tools": ["large-pot"]
        },
        {
          "id": "step-2",
          "action": "Faire revenir les oignons à feu moyen-doux jusqu'à ce qu'ils soient translucides.",
          "time": "5min",
          "inputs": [
            { "type": "ingredient", "ref": "onions" }
          ],
          "tools": ["large-pot", "wooden-spoon"],
          "output": { "state": "oignons-translucides" }
        },
        {
          "id": "step-3",
          "action": "Ajouter l'ail et faire revenir jusqu'à ce que les oignons soient dorés.",
          "time": "2min",
          "inputs": [
            { "type": "ingredient", "ref": "garlic" },
            { "type": "state", "ref": "oignons-translucides" }
          ],
          "tools": ["large-pot", "wooden-spoon"],
          "output": { "state": "oignons-dores" }
        },
        {
          "id": "step-4",
          "action": "Ajouter tous les ingrédients restants : les poivrons, les haricots, les tomates concassées, la sauce tomate, le jalapeño et toutes les épices.",
          "inputs": [
            { "type": "ingredient", "ref": "green-bell-pepper" },
            { "type": "ingredient", "ref": "red-bell-pepper" },
            { "type": "ingredient", "ref": "beans" },
            { "type": "ingredient", "ref": "diced-tomatoes" },
            { "type": "ingredient", "ref": "jalapeno" },
            { "type": "ingredient", "ref": "chili-powder" },
            { "type": "ingredient", "ref": "cocoa-powder" },
            { "type": "ingredient", "ref": "oregano" },
            { "type": "ingredient", "ref": "tomato-sauce" },
            { "type": "ingredient", "ref": "cumin" },
            { "type": "state", "ref": "oignons-dores" }
          ],
          "tools": ["large-pot", "wooden-spoon"],
          "output": { "state": "melange-chili" }
        },
        {
          "id": "step-5",
          "action": "Couvrir et porter à ébullition.",
          "inputs": [
            { "type": "state", "ref": "melange-chili" }
          ],
          "tools": ["large-pot"],
          "output": { "state": "chili-ebullition" }
        },
        {
          "id": "step-6",
          "action": "Réduire le feu et laisser mijoter doucement pendant 30 minutes, en remuant de temps en temps, jusqu'à ce que les poivrons soient tendres et que les saveurs se soient mélangées.",
          "time": "30min",
          "inputs": [
            { "type": "state", "ref": "chili-ebullition" }
          ],
          "tools": ["large-pot", "wooden-spoon"],
          "output": { "state": "chili-cuit" }
        },
        {
          "id": "step-7",
          "action": "Assaisonner avec du sel et du poivre, puis servir.",
          "inputs": [
            { "type": "state", "ref": "chili-cuit" }
          ]
        }
      ]
    }
  }
}
