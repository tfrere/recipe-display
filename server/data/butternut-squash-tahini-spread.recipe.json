  },
  "ingredientsList": [
    {
      "id": "ing1",
      "name": "butternut squash",
      "unit": "g",
      "amount": 1200
    },
    {
      "id": "ing2",
      "name": "olive oil",
      "unit": "tbsp",
      "amount": 3
    },
    {
      "id": "ing3",
      "name": "ground cinnamon",
      "unit": "tsp",
      "amount": 1
    },
    {
      "id": "ing4",
      "name": "light tahini paste",
      "unit": "g",
      "amount": 70
    },
    {
      "id": "ing5",
      "name": "greek yoghurt",
      "unit": "g",
      "amount": 120
    },
    {
      "id": "ing6",
      "name": "garlic cloves",
      "unit": "unit",
      "amount": 2
    },
    {
      "id": "ing7",
      "name": "mixed sesame seeds",
      "unit": "tsp",
      "amount": 1
    },
    {
      "id": "ing8",
      "name": "date syrup",
      "unit": "tsp",
      "amount": 1.5
    },
    {
      "id": "ing9",
      "name": "chopped coriander",
      "unit": "tbsp",
      "amount": 2
    },
