{
  "metadata": {
    "title": "Butternut Squash \u0026 Tahini Spread",
    "description": "A rich and flavorful spread made from roasted butternut squash and tahini, perfect for appetizers or as a unique condiment.",
    "servings": 6,
    "difficulty": "medium",
    "totalTime": "1h50min",
    "image": "butternut-squash-tahini-spread.jpg",
    "imageUrl": "http://recipes.tfrere.com/recipes/butternut-squash-tahini-spread/images/butternut-squash-tahini-spread.jpg",
