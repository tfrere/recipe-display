  "subRecipes": [
    {
      "id": "sub1",
      "title": "Dressing",
      "steps": [
        {
          "id": "step1",
          "action": "To make the dressing, place all the ingredients, except the oil, in a small saucepan and reduce over high heat for 5–10 minutes, or until thick and syrupy. Remove from the heat. Once cooled down, strain the sauce into a bowl and add the oil. Put aside for later.",
          "time": "15min",
          "tools": [
            "saucepan",
            "bowl",
            "strainer"
          ],
          "inputs": [
            {
              "type": "ingredient",
