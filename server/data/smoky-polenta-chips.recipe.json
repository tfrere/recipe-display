  "subRecipes": [
    {
      "id": "sub1",
      "title": "Polenta Preparation",
      "steps": [
        {
          "id": "step1",
          "action": "Bring the stock to the boil in a small saucepan. Slowly add the polenta while stirring with a wooden spoon. Cook on a gentle heat for 5-7 minutes, stirring all the time.",
          "time": "7min",
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            },
            {
              "type": "ingredient",
              "ref": "ing2"
            }
          ],
          "output": {
            "state": "cooked",
            "description": "Polenta cooked and thickened"
          }
        },
        {
          "id": "step2",
          "action": "Remove the pan from the heat and mix in the butter, cheese, ½ teaspoon of salt and a good grind of black pepper. Transfer to a small shallow tray lined with cling film and smooth out to an even layer. Leave to cool completely, then chill for at least 30 minutes.",
          "time": "40min",
          "inputs": [
            {
              "type": "state",
              "ref": "step1"
            },
            {
              "type": "ingredient",
              "ref": "ing3"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            },
            {
              "type": "ingredient",
              "ref": "ing14"
            },
            {
              "type": "ingredient",
              "ref": "ing15"
            }
          ],
          "output": {
            "state": "chilled",
            "description": "Polenta mixed with cheese and butter, cooled, and set"
          }
        }
      ]
    },
    {
      "id": "sub2",
      "title": "Tomato Sauce",
      "steps": [
        {
          "id": "step3",
          "action": "Char tomatoes in a hot pan for about 15 minutes, then break them into a bowl. Remove skins when cool enough to handle.",
          "time": "15min",
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing5"
            }
          ],
          "output": {
            "state": "charred",
            "description": "Tomatoes charred and skins removed"
          }
        },
        {
          "id": "step4",
          "action": "Cook the onion in olive oil for 5-6 minutes, add garlic and cook for another 4 minutes. Combine with tomatoes, chilli flakes, tomato purée, sugar, and ½ teaspoon of salt. Blitz to a rough paste.",
          "time": "15min",
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing6"
            },
            {
              "type": "ingredient",
              "ref": "ing7"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            },
            {
              "type": "state",
              "ref": "step3"
            },
            {
              "type": "ingredient",
              "ref": "ing9"
            },
            {
              "type": "ingredient",
              "ref": "ing10"
            },
            {
              "type": "ingredient",
              "ref": "ing11"
            },
            {
              "type": "ingredient",
              "ref": "ing14"
            }
          ],
          "output": {
            "state": "blended",
            "description": "Tomato sauce blended with onion, garlic, and seasonings"
          }
        }
      ]
    },
    {
      "id": "sub3",
      "title": "Frying Polenta Chips",
      "steps": [
        {
          "id": "step5",
          "action": "Cut the chilled polenta into chips and heat vegetable oil in a pan.",
          "time": "10min",
          "inputs": [
            {
              "type": "state",
              "ref": "step2"
            },
            {
              "type": "ingredient",
              "ref": "ing12"
            }
          ],
          "output": {
            "state": "cut and ready to fry",
            "description": "Polenta cut into chips and oil heated for frying"
          }
        },
        {
          "id": "step6",
          "action": "Toss the chips in flour, shake off excess, and fry in hot oil until golden-brown, about 6 minutes. Drain on kitchen paper.",
          "time": "6min",
          "inputs": [
            {
              "type": "state",
              "ref": "step5"
            },
            {
              "type": "ingredient",
              "ref": "ing13"
            }
          ],
          "output": {
            "state": "fried",
            "description": "Polenta chips fried to a golden-brown color and drained"
          }
        }
      ]
    }
  ]
