{
  "metadata": {
    "title": "Smoky Polenta Chips",
    "description": "smoky, crisp and cheesy with a rich tomato sauce: my version of fries with ketchup but, possibly, even more moreish. i use a smoked italian cheese, scamorza affumicata, to give these chips a deep flavour and a gorgeous melting texture, but you can happily substitute with another cheese with substantial flavour such as italian provolone or applewood smoked cheddar.",
    "servings": 4,
    "difficulty": "medium",
    "totalTime": "1h30min",
    "image": "smoky-polenta-chips.jpg",
    "imageUrl": "http://recipes.tfrere.com/recipes/smoky-polenta-chips/images/smoky-polenta-chips.jpg",
    "sourceUrl": "http://recipes.tfrere.com/recipes/smoky-polenta-chips/index.html"
  },
  "ingredientsList": [
    {
      "id": "ing1",
      "name": "vegetable stock",
      "unit": "ml",
      "amount": 375
    },
    {
      "id": "ing2",
      "name": "quick-cook polenta",
      "unit": "g",
      "amount": 60
    },
    {
      "id": "ing3",
      "name": "unsalted butter",
      "unit": "g",
      "amount": 20
    },
    {
      "id": "ing4",
      "name": "scamorza affumicata, coarsely grated",
      "unit": "g",
      "amount": 60
    },
    {
      "id": "ing5",
      "name": "large plum tomatoes",
      "unit": "unit",
      "amount": 3
    },
    {
      "id": "ing6",
      "name": "olive oil",
      "unit": "tbsp",
      "amount": 2
    },
    {
      "id": "ing7",
      "name": "medium onion, thinly sliced",
      "unit": "g",
      "amount": 100
    },
    {
      "id": "ing8",
      "name": "garlic cloves, crushed",
      "unit": "unit",
      "amount": 2
    },
    {
      "id": "ing9",
      "name": "chilli flakes",
      "unit": "tsp",
      "amount": 0.125
    },
    {
      "id": "ing10",
