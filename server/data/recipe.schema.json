{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Recipe Schema",
  "description": "Schema for recipe files",
  "type": "object",
  "required": ["metadata", "ingredients", "tools", "subRecipes"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "title",
        "description",
        "servings",
        "difficulty",
        "totalTime",
        "image"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Titre de la recette"
        },
        "description": {
          "type": "string",
          "description": "Description générale de la recette"
        },
        "servings": {
          "type": "integer",
          "description": "Nombre de portions"
        },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"],
          "description": "Niveau de difficulté"
        },
        "totalTime": {
          "type": "string",
          "description": "Temps total de préparation"
        },
        "image": {
          "type": "string",
          "description": "Nom du fichier image de la recette"
        }
      }
    },
    "ingredients": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "required": ["name", "unit", "category"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Nom de l'ingrédient"
            },
            "unit": {
              "type": "string",
              "description": "Unité de mesure"
            },
            "category": {
              "type": "string",
              "enum": [
                "base",
                "farine",
                "sucre",
                "œuf",
                "produit-laitier",
                "chocolat",
                "fruit-sec",
                "épices",
                "assaisonnement",
                "autres"
              ],
              "description": "Catégorie de l'ingrédient"
            }
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "required": ["name", "type"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Nom de l'ustensile"
            },
            "type": {
              "type": "string",
              "enum": ["cuisson", "preparation", "ustensile"],
              "description": "Type d'ustensile"
            }
          }
        }
      }
    },
    "subRecipes": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "required": ["title"],
          "properties": {
            "title": {
              "type": "string",
              "description": "Titre de la sous-recette"
            },
            "warning": {
              "type": "string",
              "description": "Avertissement ou note importante"
            },
            "ingredients": {
              "type": "object",
              "patternProperties": {
                "^.*$": {
                  "type": "object",
                  "required": ["amount"],
                  "properties": {
                    "amount": {
                      "type": "number",
                      "description": "Quantité nécessaire"
                    }
                  }
                }
              }
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "action"],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Identifiant unique de l'étape"
                  },
                  "action": {
                    "type": "string",
                    "description": "Description de l'action à effectuer"
                  },
                  "time": {
                    "type": "string",
                    "description": "Temps nécessaire pour cette étape"
                  },
                  "tools": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Liste des ustensiles nécessaires"
                  },
                  "inputs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Liste des ingrédients ou états nécessaires"
                  },
                  "output": {
                    "type": "string",
                    "description": "État résultant de l'étape"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
