            "preparation": "prepared",
            "name": "Onions removed, fat remaining"
          }
        },
        {
          "id": "step3",
          "action": "Add the livers and cook them for up to 10min, stirring from time to time, until they are properly cooked in the middle \u2014 no blood should be coming out at this stage.",
          "time": "10min",
          "stepType": "cook",
          "stepMode": "active",
          "inputs": [
