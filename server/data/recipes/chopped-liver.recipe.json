            "preparation": "fried",
            "name": "Dark brown onions"
          }
        },
        {
          "id": "step2",
          "action": "Remove the onions from the pan, pushing them down a little as you do so, so that you are left with some fat in the pan. Add a little fat if needed.",
          "time": "5min",
          "stepType": "prep",
          "stepMode": "active",
