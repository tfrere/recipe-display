      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 170\u00b0C.",
          "time": "10min",
          "stepType": "prep",
          "stepMode": "passive",
          "inputs": [],
          "output": {
            "inputType": "state",
            "ref": "step1",
            "preparation": "preheated",
            "name": "Oven preheated"
          }
        },
        {
          "id": "step2",
          "action": "Place a large ovenproof cast-iron saut\u00e9 pan on a high flame. Once hot, add the corn kernels and dry-fry for 4\u20135min, stirring from time to time, until slightly blackened. Remove from the pan and set aside to cool.",
          "time": "5min",
          "stepType": "cook",
          "stepMode": "active",
          "inputs": [
            {
              "inputType": "component",
              "ref": "tool1",
              "type": "tool",
              "amount": 1.0
            }
          ],
          "output": {
            "inputType": "state",
            "ref": "step2",
            "preparation": "dry-fried",
            "name": "Toasted corn"
          }
        },
        {
          "id": "step3",
          "action": "Sift the flour, baking powder, bicarbonate of soda, cumin and cayenne into a large bowl. Add the sugar, along with 1\u00bd teaspoons of salt and a good grind of pepper. Stir and set aside.",
          "time": "5min",
          "stepType": "prep",
          "stepMode": "active",
          "inputs": [],
          "output": {
            "inputType": "state",
            "ref": "step3",
            "preparation": "sifted and mixed",
            "name": "Dry ingredients mixture"
          }
        },
        {
          "id": "step4",
          "action": "In a separate bowl, combine the polenta, soured cream, eggs and 120ml oil and whisk lightly.",
          "time": "5min",
          "stepType": "combine",
          "stepMode": "active",
          "inputs": [],
          "output": {
            "inputType": "state",
            "ref": "step4",
            "preparation": "combined",
            "name": "Wet ingredients mixture"
          }
        },
        {
          "id": "step5",
          "action": "Add the wet ingredients to the dry ingredients, then fold in the spring onions, coriander, jalape\u00f1o and toasted corn until just combined.",
          "time": "5min",
          "stepType": "combine",
          "stepMode": "active",
          "inputs": [
            {
              "inputType": "state",
              "ref": "step3",
              "preparation": "sifted and mixed",
              "name": "Dry ingredients mixture"
            },
            {
              "inputType": "state",
              "ref": "step4",
              "preparation": "combined",
              "name": "Wet ingredients mixture"
            }
          ],
          "output": {
            "inputType": "state",
            "ref": "step5",
            "preparation": "combined",
            "name": "Cornbread batter"
          }
        },
        {
          "id": "step6",
          "action": "Use 1 tablespoon of oil to lightly grease the base and sides of the pan used to toast the corn, then pour in the cornbread mixture and scatter over all the topping ingredients.",
          "time": "5min",
          "stepType": "combine",
          "stepMode": "active",
          "inputs": [
            {
              "inputType": "component",
              "ref": "tool1",
              "type": "tool",
              "amount": 1.0
            }
          ],
          "output": {
            "inputType": "state",
            "ref": "step6",
            "preparation": "prepared",
            "name": "Cornbread ready for baking"
          }
        },
        {
          "id": "step7",
          "action": "Bake for about 40\u201345min, until a skewer comes out clean.",
          "time": "45min",
          "stepType": "cook",
          "stepMode": "passive",
          "inputs": [
            {
              "inputType": "state",
              "ref": "step6",
              "preparation": "prepared",
              "name": "Cornbread ready for baking"
            }
          ],
          "output": {
            "inputType": "state",
            "ref": "step7",
            "preparation": "baked",
            "name": "Baked cornbread"
          }
        },
        {
          "id": "step8",
          "action": "Serve the cornbread hot, straight from the oven, or leave to cool for 30 minutes and serve warm or at room temperature the same day. If serving it the next day, warm it through in the oven just before you need it.",
          "time": "30min",
          "stepType": "prep",
