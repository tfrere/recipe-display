          "action": "Pour the mixture into the prepared loaf tin and sprinkle over the remaining tablespoon of oats and seeds.",
          "time": "5min",
          "stepType": "combine",
          "stepMode": "active",
          "inputs": [
            {
              "inputType": "state",
