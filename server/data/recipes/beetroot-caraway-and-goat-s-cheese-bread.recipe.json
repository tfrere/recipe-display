            "name": "Batter in loaf tin"
          }
        },
        {
          "id": "step8",
          "action": "Bake for 40min, then cover tightly with foil and bake for another 40min. A skewer inserted into the middle will not come out completely clean but it should not be too wet.",
          "time": "1h20min",
          "stepType": "cook",
          "stepMode": "passive",
          "inputs": [
            {
              "inputType": "state",
              "ref": "step7",
              "preparation": "poured",
              "name": "Batter in loaf tin"
            }
          ],
          "output": {
            "inputType": "state",
            "ref": "step8",
            "preparation": "baked",
            "name": "Baked bread"
          }
        },
        {
          "id": "step9",
          "action": "Remove from the oven and let stand for 5min, then tip onto a wire rack and invert it back on itself so that it is seed side up. The outside will be quite crisp and dark. Cool for at least 20min before slicing.",
          "time": "25min",
          "stepType": "prep",
