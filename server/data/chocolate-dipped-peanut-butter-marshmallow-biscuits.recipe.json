{
  "metadata": {
    "title": "Chocolate-Dipped Peanut Butter Marshmallow Biscuits",
    "description": "A delightful treat combining homemade biscuits with peanut butter, marshmallow, and a chocolate dip, garnished with chopped peanuts and sea salt.",
    "servings": 22,
    "difficulty": "medium",
    "totalTime": "3h",
