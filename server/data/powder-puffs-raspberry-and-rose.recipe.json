  "subRecipes": [
    {
      "id": "sub1",
      "title": "Meringue Preparation",
      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 210°C/190°C fan/gas mark 6. Line four baking trays with baking parchment.",
          "time": "10min",
          "tools": [
            "oven",
            "baking trays",
            "baking parchment"
          ],
          "output": {
            "state": "preheated and lined",
            "description": "Oven preheated and baking trays lined with parchment"
          }
        },
        {
          "id": "step2",
          "action": "Beat egg whites until frothy, add cream of tartar, then beat until soft peaks form. Gradually add sugar to form a stiff and glossy meringue. Mix in vanilla extract and egg yolks.",
          "time": "8min",
          "tools": [
            "electric mixer",
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            },
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing3"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            }
          ],
          "output": {
            "state": "meringue",
            "description": "Stiff and glossy meringue with vanilla and egg yolks mixed in"
          }
        },
        {
          "id": "step3",
          "action": "Sift together flour, cornflour, bicarbonate of soda, and salt three times, then fold into the meringue mixture.",
          "time": "5min",
          "tools": [
            "bowl",
            "sieve"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing5"
            },
            {
              "type": "ingredient",
              "ref": "ing6"
            },
            {
              "type": "ingredient",
              "ref": "ing7"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            },
            {
              "type": "state",
              "ref": "step2"
            }
          ],
          "output": {
            "state": "batter",
            "description": "Dry ingredients folded into meringue to form a light batter"
          }
        }
      ]
    },
    {
      "id": "sub2",
      "title": "Baking and Assembly",
      "steps": [
        {
          "id": "step4",
          "action": "Drop heaped spoonfuls of batter onto lined trays and bake for 11-12 minutes.",
          "time": "12min",
          "tools": [
            "teaspoons",
            "oven",
            "baking trays"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "sub1"
            }
          ],
          "output": {
            "state": "baked",
            "description": "Baked until golden brown and starting to go crisp"
          }
        },
        {
          "id": "step5",
          "action": "After cooling, ease the biscuits away from parchment and pair them by size.",
          "time": "10min",
          "tools": [
            "palette knife"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step4"
            }
          ],
          "output": {
            "state": "paired biscuits",
            "description": "Biscuits separated from parchment and paired"
          }
        },
        {
          "id": "step6",
          "action": "Make rose cream by whisking together double cream, icing sugar, and rose water until soft peaks form.",
          "time": "3min",
          "tools": [
            "electric mixer",
            "bowl"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing11"
            },
            {
              "type": "ingredient",
              "ref": "ing12"
            },
            {
              "type": "ingredient",
              "ref": "ing13"
            }
          ],
          "output": {
            "state": "rose cream",
            "description": "Rose cream with soft peaks"
          }
        },
        {
          "id": "step7",
          "action": "Spread whipped cream and jam on biscuit bases, sandwich with tops, and refrigerate for 4 hours.",
          "time": "4h10min",
          "tools": [
            "spoon",
            "refrigerator"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step5"
            },
            {
              "type": "state",
              "ref": "step6"
            },
            {
              "type": "ingredient",
              "ref": "ing9"
            }
          ],
          "output": {
            "state": "sandwiched and chilled",
            "description": "Biscuits sandwiched with cream and jam, then chilled to soften"
          }
        },
        {
          "id": "step8",
          "action": "Remove puffs from fridge an hour before serving and dust with icing sugar.",
          "time": "1h",
          "inputs": [
            {
              "type": "state",
              "ref": "step7"
            },
            {
              "type": "ingredient",
              "ref": "ing10"
            }
          ],
          "output": {
            "state": "finished puffs",
            "description": "Puffs brought to room temperature and dusted with icing sugar"
          }
        }
      ]
    }
  ]
}