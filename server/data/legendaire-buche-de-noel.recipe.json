      "type": "ustensile"
    }
  },
  "subRecipes": {
    "creme-italienne": {
      "title": "Crème italienne au chocolat",
      "warning": "À faire en premier - nécessite du temps de refroidissement",
      "ingredients": {
        "jaunes": { "amount": 2 },
        "sucre": { "amount": 80 },
        "chocolat-noir": { "amount": 120 },
        "beurre": { "amount": 250 }
      },
      "steps": [
        {
          "id": "choc-1",
          "type": "cooking",
          "action": "Faire fondre le chocolat au bain-marie jusqu'à obtention d'une crème épaisse",
          "time": "10 min",
          "tools": ["bain-marie"],
          "inputs": [{ "type": "ingredient", "ref": "chocolat-noir" }],
          "output": {
            "state": "chocolat-fondu",
            "description": "Chocolat fondu en crème épaisse"
          }
        },
        {
          "id": "sirop-1",
          "type": "cooking",
          "action": "Faire cuire le sucre avec très peu d'eau jusqu'à ce que le sirop fasse le fil",
          "time": "5 min",
          "tools": ["casserole"],
          "inputs": [{ "type": "ingredient", "ref": "sucre" }],
          "output": {
            "state": "sirop-sucre",
            "description": "Sirop qui fait le fil"
          }
        },
        {
          "id": "jaunes-1",
          "action": "Mettre les jaunes dans un saladier placé dans une casserole très chaude",
          "time": "2 min",
          "tools": ["saladier", "casserole"],
          "inputs": [{ "type": "ingredient", "ref": "jaunes" }],
          "output": {
            "state": "jaunes-chauds",
            "description": "Jaunes d'œufs prêts à recevoir le sirop"
          }
        },
        {
          "id": "melange-1",
          "action": "Ajouter progressivement le sirop puis le chocolat, laisser cuire au bain-marie en remuant",
          "time": "10 min",
          "tools": ["fouet", "bain-marie"],
          "inputs": [
            { "type": "state", "ref": "jaunes-chauds" },
            { "type": "state", "ref": "sirop-sucre" },
            { "type": "state", "ref": "chocolat-fondu" }
          ],
          "output": {
            "state": "melange-cuit",
            "description": "Mélange cuit au bain-marie"
          }
        },
        {
          "id": "final-1",
          "type": "preparation",
          "action": "Incorporer le beurre en morceaux et travailler à froid jusqu'à épaississement",
          "time": "15 min",
          "tools": ["fouet"],
          "inputs": [
            { "type": "state", "ref": "melange-cuit" },
            { "type": "ingredient", "ref": "beurre" }
          ],
          "output": {
            "state": "creme-italienne",
            "description": "Crème italienne au chocolat épaisse"
          }
        }
      ]
    },
    "genoise": {
      "title": "Génoise",
      "ingredients": {
        "sucre-poudre": { "amount": 150 },
        "farine": { "amount": 75 },
        "maizena": { "amount": 25 },
        "oeufs": { "amount": 5 },
        "sel": { "amount": 1 }
      },
      "steps": [
        {
          "id": "sep-1",
          "type": "preparation",
          "action": "Séparer les blancs des jaunes d'œufs",
          "time": "2 min",
          "tools": ["saladier"],
          "inputs": [{ "type": "ingredient", "ref": "oeufs" }],
          "output": {
            "state": "oeufs-separes",
            "description": "Blancs et jaunes séparés"
          }
        },
        {
          "id": "jaunes-2",
          "type": "preparation",
          "action": "Battre le sucre avec les jaunes",
          "time": "5 min",
          "tools": ["fouet"],
          "inputs": [
            { "type": "state", "ref": "oeufs-separes" },
            { "type": "ingredient", "ref": "sucre-poudre" }
          ],
          "output": {
            "state": "melange-jaunes",
            "description": "Mélange jaunes et sucre"
          }
        },
        {
          "id": "farine-1",
          "type": "preparation",
          "action": "Tamiser ensemble la farine et la maïzena",
          "time": "2 min",
          "inputs": [
            { "type": "ingredient", "ref": "farine" },
            { "type": "ingredient", "ref": "maizena" }
          ],
          "output": {
            "state": "farine-tamisee",
            "description": "Farine et maïzena tamisées"
          }
        },
        {
          "id": "melange-2",
          "type": "preparation",
          "action": "Incorporer le mélange de farines aux jaunes battus avec le sucre",
          "time": "3 min",
          "tools": ["spatule"],
          "inputs": [
            { "type": "state", "ref": "melange-jaunes" },
            { "type": "state", "ref": "farine-tamisee" },
            { "type": "ingredient", "ref": "sel" }
          ],
          "output": {
            "state": "pate-base",
            "description": "Pâte de base"
          }
        },
        {
          "id": "blancs-1",
          "type": "preparation",
          "action": "Battre les blancs en neige très ferme",
          "time": "5 min",
          "tools": ["fouet"],
          "inputs": [{ "type": "state", "ref": "oeufs-separes" }],
          "output": {
            "state": "blancs-montes",
            "description": "Blancs montés en neige ferme"
          }
        },
        {
          "id": "melange-3",
          "type": "preparation",
          "action": "Incorporer délicatement les blancs à la pâte",
          "time": "3 min",
          "tools": ["spatule"],
          "inputs": [
            { "type": "state", "ref": "pate-base" },
            { "type": "state", "ref": "blancs-montes" }
          ],
          "output": {
            "state": "pate-finale",
            "description": "Pâte à génoise prête à cuire"
          }
        },
        {
          "id": "cuisson-1",
          "type": "cooking",
          "action": "Étaler la pâte sur une plaque recouverte de papier sulfurisé et cuire à 210°C",
          "time": "12 min",
          "tools": ["plaque", "papier-sulfurise"],
          "inputs": [{ "type": "state", "ref": "pate-finale" }],
          "output": {
            "state": "genoise-cuite",
            "description": "Génoise cuite"
          }
        },
        {
          "id": "refroid-1",
          "type": "preparation",
          "action": "Enrouler la génoise dans un torchon humide et laisser refroidir",
          "time": "30 min",
          "tools": ["torchon"],
          "inputs": [{ "type": "state", "ref": "genoise-cuite" }],
          "output": {
            "state": "genoise-froide",
            "description": "Génoise froide et souple"
          }
        }
      ]
    },
    "creme-patissiere": {
      "title": "Crème pâtissière aux noisettes",
      "ingredients": {
        "oeufs": { "amount": 2 },
        "farine": { "amount": 60 },
        "lait": { "amount": 40 },
        "sucre": { "amount": 80 },
        "noisettes": { "amount": 2 }
      },
      "steps": [
        {
          "id": "nois-1",
          "type": "cooking",
          "action": "Faire griller les noisettes puis les hacher finement",
          "time": "5 min",
          "tools": ["poele", "couteau"],
          "inputs": [{ "type": "ingredient", "ref": "noisettes" }],
          "output": {
            "state": "noisettes-grillees",
            "description": "Noisettes grillées et hachées"
          }
        },
        {
          "id": "lait-1",
          "type": "cooking",
          "action": "Faire bouillir le lait avec les noisettes puis filtrer",
          "time": "10 min",
          "tools": ["casserole", "passoire"],
          "inputs": [
            { "type": "ingredient", "ref": "lait" },
            { "type": "state", "ref": "noisettes-grillees" }
          ],
          "output": {
            "state": "lait-noisette",
            "description": "Lait parfumé aux noisettes"
          }
        },
        {
          "id": "app-1",
          "type": "preparation",
          "action": "Délayer la farine avec un peu d'eau froide, ajouter les œufs battus et le sucre",
          "time": "5 min",
          "tools": ["fouet"],
          "inputs": [
            { "type": "ingredient", "ref": "farine" },
            { "type": "ingredient", "ref": "oeufs" },
            { "type": "ingredient", "ref": "sucre" }
          ],
          "output": {
            "state": "appareil-creme",
            "description": "Appareil à crème pâtissière"
          }
        },
        {
          "id": "cuis-1",
          "type": "cooking",
          "action": "Mélanger avec le lait et faire bouillir en remuant jusqu'à épaississement",
          "time": "10 min",
          "tools": ["casserole", "fouet"],
          "inputs": [
            { "type": "state", "ref": "appareil-creme" },
            { "type": "state", "ref": "lait-noisette" }
          ],
          "output": {
            "state": "creme-patissiere",
            "description": "Crème pâtissière aux noisettes"
          }
        },
        {
          "id": "refroid-2",
          "type": "preparation",
          "action": "Laisser refroidir la crème",
          "time": "30 min",
          "inputs": [{ "type": "state", "ref": "creme-patissiere" }],
          "output": {
            "state": "creme-patissiere-froide",
            "description": "Crème pâtissière refroidie"
          }
        }
      ]
    },
    "assemblage": {
      "title": "Assemblage de la bûche",
      "steps": [
        {
          "id": "ass-1",
          "type": "assembly",
          "action": "Dérouler la génoise avec le torchon humide",
          "time": "2 min",
          "tools": ["torchon"],
          "inputs": [{ "type": "subRecipe", "ref": "genoise/genoise-froide" }],
          "output": {
            "state": "genoise-deroulee",
            "description": "Génoise déroulée"
          }
        },
        {
          "id": "ass-2",
          "type": "assembly",
          "action": "Étaler la crème pâtissière sur toute la surface",
          "time": "5 min",
          "tools": ["spatule"],
          "inputs": [
            { "type": "state", "ref": "genoise-deroulee" },
            {
              "type": "subRecipe",
              "ref": "creme-patissiere/creme-patissiere-froide"
            }
          ],
          "output": {
            "state": "genoise-garnie",
            "description": "Génoise garnie de crème"
          }
        },
        {
          "id": "ass-3",
          "type": "assembly",
          "action": "Rouler la bûche en serrant bien",
          "time": "5 min",
          "tools": ["couteau"],
          "inputs": [{ "type": "state", "ref": "genoise-garnie" }],
          "output": {
            "state": "buche-base",
            "description": "Bûche roulée avec bords coupés"
          }
        },
        {
          "id": "ass-4",
          "type": "assembly",
          "action": "Recouvrir entièrement de crème italienne au chocolat",
          "time": "10 min",
          "tools": ["spatule"],
          "inputs": [
            { "type": "state", "ref": "buche-base" },
            { "type": "subRecipe", "ref": "creme-italienne/creme-italienne" }
          ],
          "output": {
            "state": "buche-recouverte",
            "description": "Bûche recouverte de crème au chocolat"
          }
        },
        {
          "id": "ass-5",
          "type": "assembly",
          "action": "Strier la surface avec une fourchette pour imiter l'écorce",
          "time": "5 min",
          "tools": ["fourchette"],
          "inputs": [{ "type": "state", "ref": "buche-recouverte" }],
          "output": {
            "state": "buche-striee",
            "description": "Bûche avec motifs d'écorce"
          }
        },
        {
          "id": "ass-6",
          "type": "assembly",
          "action": "Saupoudrer légèrement de sucre glace",
          "time": "1 min",
          "inputs": [
            { "type": "state", "ref": "buche-striee" },
            { "type": "ingredient", "ref": "sucre-glace" }
          ],
          "output": {
            "state": "buche-finale",
            "description": "Bûche de Noël terminée"
          }
        }
      ]
    }
  }
}
