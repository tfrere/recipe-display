{
  "metadata": {
    "title": "Légendaire Bûche de Noël",
    "description": "Une bûche de Noël traditionnelle avec une génoise moelleuse, une crème pâtissière aux noisettes et une crème italienne au chocolat",
    "servings": 8,
    "difficulty": "hard",
    "totalTime": "3h",
    "image": "legendaire-buche-de-noel.jpg"
  },
