{
  "metadata": {
    "title": "Roasted Asparagus with Almonds, Capers and Dill",
    "description": "This is a dish which my husband Karl cooks at home a lot, on the weekend. He tends to be a bit more liberal on the butter front with his asparagus – what are weekends for, after all! And he is Irish!",
    "servings": 4,
    "difficulty": "easy",
    "totalTime": "22min",
