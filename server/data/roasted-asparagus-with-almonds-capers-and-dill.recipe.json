  "subRecipes": [
    {
      "id": "sub1",
      "title": "Roasting Asparagus",
      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 200°C fan.",
          "time": "10min",
          "tools": [
            "oven"
          ],
          "output": {
            "state": "preheated",
            "description": "Oven preheated to correct temperature"
          }
        },
        {
          "id": "step2",
          "action": "Mix the asparagus with 1 tablespoon of oil, a generous pinch of salt and a good grind of pepper. Arrange on a large parchment-lined baking tray, spaced well apart, and roast for 8–12 minutes, until the asparagus is soft and starting to brown in places. Transfer to a large serving plate and set aside.",
          "time": "12min",
          "tools": [
            "baking tray",
            "parchment paper"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            },
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing7"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            }
          ],
          "output": {
            "state": "roasted",
            "description": "Asparagus is soft and starting to brown"
          }
        }
      ]
    },
    {
      "id": "sub2",
      "title": "Preparing Almonds and Capers",
      "steps": [
        {
          "id": "step3",
          "action": "Put the butter into a small saucepan and place on a medium-high heat. Once melted, add the almonds and fry for 1–2 minutes, stirring frequently, until the almonds are golden-brown. Pour the almonds and butter evenly over the asparagus.",
          "time": "2min",
          "tools": [
            "saucepan"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing3"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            },
            {
              "type": "state",
              "ref": "step2"
            }
          ],
          "output": {
            "state": "almonds fried",
            "description": "Almonds are golden-brown and poured over asparagus"
          }
        },
        {
          "id": "step4",
          "action": "Add the remaining 2 tablespoons of oil to the saucepan and place on a high heat. Once hot, add the capers and fry for 1–2 minutes, stirring continuously, until they have opened up and become crisp. Using a slotted spoon, remove the capers from the oil and sprinkle over the asparagus, along with the dill. Discard the oil and serve warm.",
          "time": "2min",
          "tools": [
            "saucepan",
            "slotted spoon"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing5"
            },
            {
              "type": "ingredient",
              "ref": "ing6"
            },
            {
              "type": "state",
              "ref": "step3"
            }
          ],
          "output": {
            "state": "completed dish",
            "description": "Capers are crisp and sprinkled over asparagus with dill"
          }
        }
      ]
    }
  ]
