  "subRecipes": [
    {
      "id": "sub1",
      "title": "Pastry Case Preparation",
      "steps": [
        {
          "id": "step1",
          "action": "Lightly brush an 18cm loose-based cake tin with vegetable oil, then set aside.",
          "time": "5min",
          "tools": [
            "cake tin",
            "brush"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            }
          ],
          "output": {
            "state": "prepared tin",
            "description": "Cake tin brushed with oil and ready for pastry"
          }
        },
        {
          "id": "step2",
          "action": "Roll out the sweet pastry on a floured surface and line the tin with it. Trim the edges and place in the fridge to rest for 30 minutes.",
          "time": "40min",
          "tools": [
            "rolling pin",
            "fridge"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing3"
            },
            {
              "type": "state",
              "ref": "step1"
            }
          ],
          "output": {
            "state": "lined tin",
            "description": "Pastry case lined in the cake tin and rested"
          }
        },
        {
          "id": "step3",
          "action": "Preheat the oven and bake the pastry case blind until light brown.",
          "time": "35min",
          "tools": [
            "oven",
            "baking parchment"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step2"
            }
          ],
          "output": {
            "state": "baked case",
            "description": "Pastry case baked blind and ready for filling"
          }
        }
      ]
    },
    {
      "id": "sub2",
      "title": "Filling Preparation",
      "steps": [
        {
          "id": "step4",
          "action": "Prepare the semolina filling by combining butter, cream, milk, sugar and vanilla. Whisk in the semolina and egg. Remove the vanilla pod.",
          "time": "20min",
          "tools": [
            "saucepan",
            "whisk"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing4"
            },
            {
              "type": "ingredient",
              "ref": "ing5"
            },
            {
              "type": "ingredient",
              "ref": "ing6"
            },
            {
              "type": "ingredient",
              "ref": "ing7"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            },
            {
              "type": "ingredient",
              "ref": "ing9"
            },
            {
              "type": "ingredient",
              "ref": "ing10"
            }
          ],
          "output": {
            "state": "prepared filling",
            "description": "Semolina filling prepared and ready to be poured into pastry case"
          }
        },
        {
          "id": "step5",
          "action": "Pour the semolina mixture into the baked pastry case, add raspberries, and bake until slightly golden.",
          "time": "25min",
          "tools": [
            "oven"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step3"
            },
            {
              "type": "state",
              "ref": "step4"
            },
            {
              "type": "ingredient",
              "ref": "ing11"
            }
          ],
          "output": {
            "state": "baked tart",
            "description": "Semolina and raspberry tart baked and slightly golden"
          }
        }
      ]
    },
    {
      "id": "sub3",
      "title": "Finishing Touches",
      "steps": [
        {
          "id": "step6",
          "action": "Glaze the tart with apricot jam and finish with fresh raspberries and a dusting of icing sugar.",
