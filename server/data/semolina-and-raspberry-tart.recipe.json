              "ref": "ing13"
            },
            {
              "type": "state",
              "ref": "step5"
            }
          ],
          "output": {
            "state": "finished tart",
            "description": "Tart glazed with apricot jam and decorated with fresh raspberries and icing sugar"
          }
        }
      ]
