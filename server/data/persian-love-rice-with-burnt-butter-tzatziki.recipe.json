    "melange-epices": {
      "title": "Mélange d'épices persan",
      "ingredients": {
        "petales-rose": { "amount": 1 },
        "coriandre-graines": { "amount": 1 },
        "cardamome": { "amount": 0.75 },
        "muscade": { "amount": 0.25 },
        "cannelle": { "amount": 0.25 },
        "poivre-noir": { "amount": 0.25 }
      },
      "steps": [
        {
          "id": "epices-1",
          "type": "preparation",
          "name": "Mélanger et moudre tous les ingrédients pour le mélange d'épices persan",
          "action": "Mélanger et moudre tous les ingrédients pour le mélange d'épices persan",
          "time": "5min",
          "tools": ["mortier", "pilon"],
          "inputs": [
            { "type": "ingredient", "ref": "petales-rose" },
            { "type": "ingredient", "ref": "coriandre-graines" },
            { "type": "ingredient", "ref": "cardamome" },
            { "type": "ingredient", "ref": "muscade" },
            { "type": "ingredient", "ref": "cannelle" },
            { "type": "ingredient", "ref": "poivre-noir" }
          ],
          "output": {
            "state": "melange-epices-pret",
            "description": "Mélange d'épices homogène et finement moulu"
          }
        }
      ]
    },
    "tzatziki": {
      "title": "Tzatziki au beurre noisette",
      "ingredients": {
        "courgettes": { "amount": 2 },
        "yaourt-grec": { "amount": 200 },
        "jus-citron": { "amount": 2 },
        "ciboulette": { "amount": 10 },
        "menthe": { "amount": 10 },
        "beurre": { "amount": 30 }
      },
      "steps": [
        {
          "id": "tzatziki-1",
          "type": "preparation",
          "name": "Râper les courgettes et les égoutter dans une passoire avec du sel",
          "action": "Râper les courgettes et les égoutter dans une passoire avec du sel",
          "time": "30min",
          "tools": ["passoire", "rape"],
          "inputs": [
            { "type": "ingredient", "ref": "courgettes" }
          ],
          "output": {
            "state": "courgettes-egouttes",
            "description": "Courgettes râpées et égouttées"
          }
        },
        {
          "id": "tzatziki-2",
          "type": "cooking",
          "name": "Faire un beurre noisette : faire fondre le beurre jusqu'à ce qu'il devienne doré et dégage une odeur de noisette",
          "action": "Faire un beurre noisette : faire fondre le beurre jusqu'à ce qu'il devienne doré et dégage une odeur de noisette",
          "time": "5min",
          "tools": ["casserole"],
          "inputs": [
            { "type": "ingredient", "ref": "beurre" }
          ],
          "output": {
            "state": "beurre-noisette",
            "description": "Beurre noisette doré et parfumé"
          }
        },
        {
          "id": "tzatziki-3",
          "type": "preparation",
          "name": "Mélanger le yaourt grec avec les courgettes égouttées, le jus de citron, la ciboulette et la menthe ciselées",
          "action": "Mélanger le yaourt grec avec les courgettes égouttées, le jus de citron, la ciboulette et la menthe ciselées",
          "time": "5min",
          "tools": ["saladier"],
          "inputs": [
            { "type": "state", "ref": "courgettes-egouttes" },
            { "type": "ingredient", "ref": "yaourt-grec" },
            { "type": "ingredient", "ref": "jus-citron" },
            { "type": "ingredient", "ref": "ciboulette" },
            { "type": "ingredient", "ref": "menthe" }
          ],
          "output": {
            "state": "tzatziki-base",
            "description": "Mélange de yaourt aux herbes et courgettes"
          }
        },
        {
          "id": "tzatziki-4",
          "type": "assembly",
          "name": "Incorporer le beurre noisette refroidi au tzatziki",
          "action": "Incorporer le beurre noisette refroidi au tzatziki",
          "time": "2min",
          "tools": ["fouet"],
          "inputs": [
            { "type": "state", "ref": "tzatziki-base" },
            { "type": "state", "ref": "beurre-noisette" }
          ],
          "output": {
            "state": "tzatziki-final",
            "description": "Tzatziki au beurre noisette"
          }
        }
      ]
    },
    "riz-persan": {
      "title": "Riz aux fruits secs et épices",
      "ingredients": {
        "mures-seches": { "amount": 30 },
        "baies-berberes": { "amount": 40 },
        "feuilles-vigne": { "amount": 8 },
        "huile-olive": { "amount": 2 },
        "oignon": { "amount": 1 },
        "ail": { "amount": 3 },
        "gingembre": { "amount": 3 },
        "safran": { "amount": 1 },
        "riz-basmati": { "amount": 300 },
        "bouillon-legumes": { "amount": 550 },
        "carotte": { "amount": 1 },
        "amandes": { "amount": 50 },
        "pistaches": { "amount": 50 },
        "huile-tournesol": { "amount": 3 }
      },
      "steps": [
        {
          "id": "riz-1",
          "type": "preparation",
          "name": "Faire tremper le riz 30 minutes dans l'eau froide puis égoutter",
          "action": "Faire tremper le riz 30 minutes dans l'eau froide puis égoutter",
          "time": "30min",
          "tools": ["saladier", "passoire"],
          "inputs": [
            { "type": "ingredient", "ref": "riz-basmati" }
          ],
          "output": {
            "state": "riz-trempe",
            "description": "Riz trempé et égoutté"
          }
        },
        {
          "id": "riz-2",
          "type": "preparation",
          "name": "Émincer l'oignon, l'ail et râper le gingembre",
          "action": "Émincer l'oignon, l'ail et râper le gingembre",
          "time": "10min",
          "tools": ["couteau", "rape"],
          "inputs": [
            { "type": "ingredient", "ref": "oignon" },
            { "type": "ingredient", "ref": "ail" },
            { "type": "ingredient", "ref": "gingembre" }
          ],
          "output": {
            "state": "aromates-prepares",
            "description": "Aromates émincés et râpés"
          }
        },
        {
          "id": "riz-3",
          "type": "cooking",
          "name": "Faire revenir les aromates dans l'huile d'olive avec le safran",
          "action": "Faire revenir les aromates dans l'huile d'olive avec le safran",
          "time": "5min",
          "tools": ["casserole"],
          "inputs": [
            { "type": "state", "ref": "aromates-prepares" },
            { "type": "ingredient", "ref": "huile-olive" },
            { "type": "ingredient", "ref": "safran" }
          ],
          "output": {
            "state": "aromates-revenus",
            "description": "Aromates revenus et parfumés"
          }
        },
        {
          "id": "riz-4",
          "type": "cooking",
          "name": "Ajouter le riz égoutté et le bouillon, cuire à feu doux 18-20 minutes",
          "action": "Ajouter le riz égoutté et le bouillon, cuire à feu doux 18-20 minutes",
          "time": "20min",
          "tools": ["casserole"],
          "inputs": [
            { "type": "state", "ref": "aromates-revenus" },
            { "type": "state", "ref": "riz-trempe" },
            { "type": "ingredient", "ref": "bouillon-legumes" }
          ],
          "output": {
            "state": "riz-cuit",
            "description": "Riz cuit parfumé aux aromates"
          }
        },
        {
          "id": "riz-5",
          "type": "preparation",
          "name": "Torréfier les amandes et les pistaches",
          "action": "Torréfier les amandes et les pistaches",
          "time": "5min",
          "tools": ["poele"],
          "inputs": [
            { "type": "ingredient", "ref": "amandes" },
            { "type": "ingredient", "ref": "pistaches" }
          ],
          "output": {
            "state": "fruits-secs-torrefies",
            "description": "Fruits secs dorés et croustillants"
          }
        },
        {
          "id": "riz-6",
          "type": "assembly",
          "name": "Mélanger le riz avec les fruits secs, les mûres, les baies de berbéris et le mélange d'épices",
          "action": "Mélanger le riz avec les fruits secs, les mûres, les baies de berbéris et le mélange d'épices",
          "time": "5min",
          "tools": ["saladier"],
          "inputs": [
            { "type": "state", "ref": "riz-cuit" },
            { "type": "state", "ref": "fruits-secs-torrefies" },
            { "type": "ingredient", "ref": "mures-seches" },
            { "type": "ingredient", "ref": "baies-berberes" },
            { "type": "subRecipe", "ref": "melange-epices" }
          ],
          "output": {
            "state": "riz-final",
            "description": "Riz persan aux fruits secs et épices"
          }
        }
      ]
    }
  }
