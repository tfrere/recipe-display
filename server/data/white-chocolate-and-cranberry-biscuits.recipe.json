            {
              "type": "state",
              "ref": "step3"
            }
          ],
          "output": {
            "state": "egg mixed",
            "description": "The egg is fully incorporated into the butter mixture."
          }
        },
        {
          "id": "step5",
          "action": "Mix in the sifted flour mixture and oats until just combined.",
          "time": "5min",
          "tools": [
            "large mixing bowl",
            "wooden spoon"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step2"
            },
            {
              "type": "ingredient",
              "ref": "ing10"
            },
            {
              "type": "state",
              "ref": "step4"
            }
          ],
          "output": {
            "state": "dough formed",
            "description": "The biscuit dough is formed with flour and oats mixed in."
          }
        },
        {
          "id": "step6",
          "action": "Fold in the chopped white chocolate and dried cranberries.",
          "time": "5min",
          "tools": [
            "large mixing bowl",
            "wooden spoon"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing11"
            },
            {
              "type": "ingredient",
              "ref": "ing12"
            },
            {
              "type": "state",
              "ref": "step5"
            }
          ],
          "output": {
            "state": "chocolate and cranberries folded",
            "description": "White chocolate and dried cranberries are folded into the dough."
          }
        }
