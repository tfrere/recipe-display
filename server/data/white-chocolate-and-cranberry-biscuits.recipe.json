  "subRecipes": [
    {
      "id": "sub1",
      "title": "Biscuit Dough Preparation",
      "steps": [
        {
          "id": "step1",
          "action": "Preheat the oven to 190°C/170°C fan/gas mark 5.",
          "time": "5min",
          "tools": [
            "oven"
          ],
          "inputs": [],
          "output": {
            "state": "oven preheated",
            "description": "The oven is preheated to the correct temperature."
          }
        },
        {
          "id": "step2",
          "action": "Sift together the flour, salt, baking powder, and bicarbonate of soda.",
          "time": "5min",
          "tools": [
            "sift"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing1"
            },
            {
              "type": "ingredient",
              "ref": "ing2"
            },
            {
              "type": "ingredient",
              "ref": "ing3"
            },
            {
              "type": "ingredient",
              "ref": "ing4"
            }
          ],
          "output": {
            "state": "sifted",
            "description": "The dry ingredients are sifted together."
          }
        },
        {
          "id": "step3",
          "action": "Beat the butter, vanilla essence, and both sugars until lighter in color and texture.",
          "time": "10min",
          "tools": [
            "large mixing bowl",
            "wooden spoon"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing5"
            },
            {
              "type": "ingredient",
              "ref": "ing6"
            },
            {
              "type": "ingredient",
              "ref": "ing7"
            },
            {
              "type": "ingredient",
              "ref": "ing8"
            }
          ],
          "output": {
            "state": "creamed",
            "description": "The butter mixture is creamed with sugars and vanilla."
          }
        },
        {
          "id": "step4",
          "action": "Gradually add the beaten egg to the butter mixture.",
          "time": "5min",
          "tools": [
            "large mixing bowl",
            "wooden spoon"
          ],
          "inputs": [
            {
              "type": "ingredient",
              "ref": "ing9"
