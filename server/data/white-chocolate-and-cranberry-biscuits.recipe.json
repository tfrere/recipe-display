    },
    {
      "id": "sub2",
      "title": "Baking",
      "steps": [
        {
          "id": "step7",
          "action": "Chill the biscuit dough slightly.",
          "time": "15min",
          "tools": [],
          "inputs": [
            {
              "type": "state",
              "ref": "step6"
            }
          ],
          "output": {
            "state": "dough chilled",
            "description": "The biscuit dough is chilled to make shaping easier."
          }
        },
        {
          "id": "step8",
          "action": "Scoop out portions of the dough and roll into balls.",
          "time": "10min",
          "tools": [
            "spoon"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step7"
            }
          ],
          "output": {
            "state": "dough portioned",
            "description": "The dough is portioned and rolled into balls."
          }
        },
        {
          "id": "step9",
          "action": "Place the dough balls on baking trays lined with parchment, spaced apart.",
          "time": "5min",
          "tools": [
            "baking trays",
            "baking parchment"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step8"
            }
          ],
          "output": {
            "state": "dough balls placed",
            "description": "The dough balls are placed on the baking trays ready for baking."
          }
        },
        {
          "id": "step10",
          "action": "Bake in the preheated oven until a good brown color.",
          "time": "10min",
          "tools": [
            "oven",
            "baking trays"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step1"
            },
            {
              "type": "state",
              "ref": "step9"
            }
          ],
          "output": {
            "state": "biscuits baked",
            "description": "The biscuits are baked to a good brown color."
          }
        },
        {
          "id": "step11",
          "action": "Allow to cool on the trays before serving.",
          "time": "10min",
          "tools": [
            "baking trays"
          ],
          "inputs": [
            {
              "type": "state",
              "ref": "step10"
            }
          ],
          "output": {
            "state": "biscuits cooled",
            "description": "The biscuits are cooled and ready to be served."
          }
