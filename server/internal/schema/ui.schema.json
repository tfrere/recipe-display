{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "description", "servings", "difficulty", "image", "ingredients", "subRecipes", "diet", "season", "quick", "metadata"],
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "servings": { "type": "number" },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "diet": {
      "type": "string",
      "enum": ["normal", "vegetarian", "vegan"]
    },
    "season": {
      "type": "string",
      "enum": ["spring", "summer", "autumn", "winter"]
    },
    "quick": {
      "type": "boolean",
      "description": "Indicates if the recipe can be made in less than 30 minutes"
    },
    "image": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["description", "servings", "difficulty", "totalTime", "image", "imageUrl", "sourceUrl", "diet", "season", "recipeType", "quick"],
      "properties": {
        "description": { "type": "string" },
        "servings": { "type": "number" },
        "difficulty": { "type": "string" },
        "totalTime": { "type": "string" },
        "image": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "diet": { "type": "string" },
        "season": { "type": "string" },
        "recipeType": { "type": "string" },
        "quick": { "type": "boolean" }
      }
    },
    "ingredients": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9-]+$": {
          "type": "object",
          "required": ["name", "unit", "category"],
          "properties": {
            "name": { "type": "string" },
            "unit": { "type": "string" },
            "category": { "type": "string" },
            "state": {
              "type": "string",
              "title": "Preparation State",
              "description": "How the ingredient should be prepared (optional)"
            }
          }
        }
      }
    },
    "subRecipes": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9-]+$": {
          "type": "object",
          "required": ["title", "ingredients", "steps"],
          "properties": {
            "title": { "type": "string" },
            "warning": { "type": "string" },
            "ingredients": {
              "type": "object",
              "patternProperties": {
                "^[a-zA-Z0-9-]+$": {
                  "type": "object",
                  "required": ["amount"],
                  "properties": {
                    "amount": { "type": "number" }
                  }
                }
              }
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "action"],
                "properties": {
                  "id": { "type": "string" },
                  "type": { 
                    "type": "string",
                    "enum": ["preparation", "cooking"]
                  },
                  "action": { "type": "string" },
                  "time": { "type": "string" },
                  "tools": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "inputs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["type", "ref"],
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["ingredient", "state"]
                        },
                        "ref": { "type": "string" }
                      }
                    }
                  },
                  "output": {
                    "type": "object",
                    "required": ["state", "description"],
                    "properties": {
                      "state": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
