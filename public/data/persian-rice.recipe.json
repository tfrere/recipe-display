  "subRecipes": {
    "melange-epices": {
      "title": "Mélange d'épices persan",
      "ingredients": {
        "petales-rose": { "amount": 1 },
        "coriandre-graines": { "amount": 1 },
        "cardamome": { "amount": 0.75 },
        "muscade": { "amount": 0.25 },
        "cannelle": { "amount": 0.25 },
        "poivre-noir": { "amount": 0.25 }
      },
      "steps": [
        {
          "id": "epices-1",
          "type": "preparation",
          "text": "Mélanger tous les ingrédients pour le mélange d'épices persan",
          "time": "5min",
          "tools": [],
          "inputs": [
            { "type": "ingredient", "ref": "petales-rose" },
            { "type": "ingredient", "ref": "coriandre-graines" },
            { "type": "ingredient", "ref": "cardamome" },
            { "type": "ingredient", "ref": "muscade" },
            { "type": "ingredient", "ref": "cannelle" },
            { "type": "ingredient", "ref": "poivre-noir" }
          ],
          "output": {
            "state": "melange-epices"
          }
        }
      ]
    },
    "tzatziki": {
      "title": "Tzatziki au beurre noisette",
      "ingredients": {
        "courgettes": { "amount": 2 },
        "yaourt-grec": { "amount": 140 },
        "jus-citron": { "amount": 2 },
        "ciboulette": { "amount": 5 },
        "menthe": { "amount": 5 },
        "beurre": { "amount": 50 }
      },
      "steps": [
        {
          "id": "tzatziki-1",
          "type": "preparation",
          "text": "Râper les courgettes et les saler. Laisser égoutter 15 minutes puis presser pour retirer l'excès d'eau",
          "time": "15min",
          "tools": ["passoire", "rape"],
          "inputs": [{ "type": "ingredient", "ref": "courgettes" }],
          "output": {
            "state": "courgettes-rapees"
          }
        },
        {
          "id": "tzatziki-2",
          "type": "preparation",
          "text": "Faire un beurre noisette : faire fondre le beurre jusqu'à ce qu'il devienne brun et dégage une odeur de noisette",
          "time": "2min",
          "tools": ["casserole"],
          "inputs": [{ "type": "ingredient", "ref": "beurre" }],
          "output": {
            "state": "beurre-noisette"
          }
        },
        {
          "id": "tzatziki-3",
          "type": "preparation",
          "text": "Mélanger les courgettes avec le yaourt, le jus de citron, la ciboulette, la menthe et le beurre noisette",
          "time": "5min",
          "tools": ["saladier"],
          "inputs": [
            { "type": "state", "ref": "courgettes-rapees" },
            { "type": "state", "ref": "beurre-noisette" },
            { "type": "ingredient", "ref": "yaourt-grec" },
            { "type": "ingredient", "ref": "jus-citron" },
            { "type": "ingredient", "ref": "ciboulette" },
            { "type": "ingredient", "ref": "menthe" }
          ],
          "output": {
            "state": "tzatziki-complet"
          }
        }
      ]
    },
    "riz-persan": {
      "title": "Riz aux fruits secs et épices",
      "ingredients": {
        "mures-seches": { "amount": 30 },
        "baies-berberes": { "amount": 40 },
        "feuilles-vigne": { "amount": 24 },
        "huile-olive": { "amount": 1 },
        "oignon": { "amount": 1 },
        "ail": { "amount": 2 },
        "gingembre": { "amount": 3 },
        "safran": { "amount": 1 },
        "riz-basmati": { "amount": 125 },
        "bouillon-legumes": { "amount": 300 },
        "carotte": { "amount": 1 },
        "amandes": { "amount": 40 },
        "pistaches": { "amount": 40 },
        "huile-tournesol": { "amount": 1 }
      },
      "steps": [
        {
          "id": "riz-1",
          "type": "preparation",
          "text": "Faire tremper les mûres et les baies de berbéris dans de l'eau chaude pendant 10 minutes puis égoutter",
          "time": "10min",
          "tools": ["passoire"],
          "inputs": [
            { "type": "ingredient", "ref": "mures-seches" },
            { "type": "ingredient", "ref": "baies-berberes" }
          ],
          "output": {
            "state": "fruits-trempes"
          }
        },
        {
          "id": "riz-2",
          "type": "cuisson",
          "text": "Faire cuire les feuilles de vigne dans l'eau bouillante pendant 15 minutes jusqu'à ce qu'elles soient tendres",
          "time": "15min",
          "tools": ["casserole"],
          "inputs": [{ "type": "ingredient", "ref": "feuilles-vigne" }],
          "output": {
            "state": "feuilles-cuites"
          }
        },
        {
          "id": "riz-3",
          "type": "cuisson",
          "text": "Faire revenir l'oignon, l'ail et le gingembre dans l'huile d'olive",
          "time": "5min",
          "tools": ["poele"],
          "inputs": [
            { "type": "ingredient", "ref": "huile-olive" },
            { "type": "ingredient", "ref": "oignon" },
            { "type": "ingredient", "ref": "ail" },
            { "type": "ingredient", "ref": "gingembre" }
          ],
          "output": {
            "state": "base-aromatique"
          }
        },
        {
          "id": "riz-4",
          "type": "cuisson",
          "text": "Ajouter le mélange d'épices, le safran et le riz. Faire revenir puis ajouter le bouillon et cuire couvert pendant 12 minutes",
          "time": "15min",
          "tools": ["poele"],
          "inputs": [
            { "type": "state", "ref": "base-aromatique" },
            { "type": "state", "ref": "melange-epices" },
            { "type": "ingredient", "ref": "safran" },
            { "type": "ingredient", "ref": "riz-basmati" },
            { "type": "ingredient", "ref": "bouillon-legumes" }
          ],
          "output": {
            "state": "riz-cuit"
          }
        },
        {
          "id": "riz-5",
          "type": "preparation",
          "text": "Incorporer les fruits trempés, la carotte râpée, les amandes et les pistaches au riz",
          "time": "5min",
          "tools": [],
          "inputs": [
            { "type": "state", "ref": "riz-cuit" },
            { "type": "state", "ref": "fruits-trempes" },
            { "type": "ingredient", "ref": "carotte" },
            { "type": "ingredient", "ref": "amandes" },
            { "type": "ingredient", "ref": "pistaches" }
          ],
          "output": {
            "state": "riz-garni"
          }
        },
        {
          "id": "riz-6",
          "type": "preparation",
          "text": "Former les paquets avec les feuilles de vigne et le riz, en utilisant les emporte-pièces et le film alimentaire",
          "time": "20min",
          "tools": ["emporte-piece", "film-alimentaire"],
          "inputs": [
            { "type": "state", "ref": "riz-garni" },
            { "type": "state", "ref": "feuilles-cuites" }
          ],
          "output": {
            "state": "paquets-formes"
          }
        },
        {
          "id": "riz-7",
          "type": "cuisson",
          "text": "Faire dorer les paquets à la poêle puis finir au four à 200°C pendant 10 minutes",
          "time": "15min",
          "tools": ["poele", "pinceau"],
          "inputs": [
            { "type": "state", "ref": "paquets-formes" },
            { "type": "ingredient", "ref": "huile-tournesol" }
          ],
          "output": {
            "state": "paquets-cuits"
          }
        }
      ]
    }
  }
}
